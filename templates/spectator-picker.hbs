{{!--
  Spectator picker body. Rendered by SpectatorPicker (ApplicationV2).
  [data-action] elements are auto-wired to the app's action handlers; live text
  filtering and the whole-row click target are wired manually in _onRender (the
  row is not a [data-action] element so it can never double-fire alongside the
  GM buttons nested inside it).
--}}
<div class="ds-picker-body">
  <div class="ds-picker-toolbar">
    <div class="ds-search">
      <i class="fa-solid fa-magnifying-glass"></i>
      <input type="text" data-ds-search placeholder="{{localize 'dynamic-spectator.picker.search'}}" />
    </div>
  </div>

  {{#if hasRows}}
  <ul class="ds-token-list">
    {{#each rows}}
    <li class="ds-token-row {{#if this.current}}current{{/if}}" role="button" tabindex="0"
        data-ds-row data-token-id="{{this.tokenId}}" data-name="{{this.name}}"
        title="{{#if this.current}}{{localize 'dynamic-spectator.picker.stop'}}{{else}}{{localize 'dynamic-spectator.picker.spectate'}}{{/if}}">
      <img class="ds-token-portrait" src="{{this.img}}" alt="" />
      <div class="ds-token-info">
        <span class="ds-token-name">{{this.name}}</span>
        <span class="ds-token-meta">
          <span class="ds-disposition disp-{{this.disposition}}">{{this.dispositionLabel}}</span>
          {{#if this.isNpc}}<span class="ds-npc-tag">{{localize 'dynamic-spectator.picker.npc'}}</span>{{/if}}
          <span class="ds-token-elev"><i class="fa-solid fa-mountain"></i> {{this.elevation}}</span>
        </span>
      </div>
      {{#if ../isGM}}
      <div class="ds-token-actions">
        {{#if this.isNpc}}
        <button type="button" class="ds-btn ds-npc-toggle {{#if this.npcOptIn}}active{{/if}}"
                data-action="toggleNpc"
                title="{{localize 'dynamic-spectator.picker.toggleNpc'}}">
          <i class="fa-solid {{#if this.npcOptIn}}fa-user-check{{else}}fa-user-slash{{/if}}"></i>
        </button>
        {{else}}
        <button type="button" class="ds-btn" data-action="optOut" title="{{localize 'dynamic-spectator.picker.optOut'}}">
          <i class="fa-solid fa-ban"></i>
        </button>
        {{/if}}
      </div>
      {{/if}}
      {{#if ../perTokenEnabled}}
      <button type="button" class="ds-btn ds-ring-btn {{#if ../ringHoverOnly}}ds-ring-btn-hover-only{{/if}}"
              data-action="ringSettings"
              title="{{localize 'dynamic-spectator.picker.ringSettings'}}">
        <i class="fa-solid fa-palette"></i>
      </button>
      {{/if}}
      <i class="fa-solid fa-eye ds-row-state"></i>
    </li>
    {{/each}}
  </ul>
  {{else}}
  <p class="ds-empty">{{localize 'dynamic-spectator.picker.empty'}}</p>
  {{/if}}

  {{#if spectating}}
  <button type="button" class="ds-stop" data-action="stop">
    <i class="fa-solid fa-eye-slash"></i> {{localize 'dynamic-spectator.picker.stop'}} <kbd>Esc</kbd>
  </button>
  {{/if}}

  <div class="ds-picker-footer">BGS: Dynamic Spectator v{{version}}</div>
</div>
