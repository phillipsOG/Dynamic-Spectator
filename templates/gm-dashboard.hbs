{{!--
  GM dashboard body. Rendered by GMDashboard (ApplicationV2).
  Context: { players, hasPlayers }, where each player carries a prebuilt
  permissionOptions list ({ value, label, selected }) — core ships no `eq`
  helper, so the selected option is resolved in _prepareContext, not here.
  The <select> is wired on `change` in _onRender rather than via [data-action].
--}}
<div class="ds-dashboard-body">
  <section class="ds-dash-section">
    <h3><i class="fa-solid fa-user-group"></i> {{localize 'dynamic-spectator.dashboard.players'}}</h3>
    {{#if hasPlayers}}
    <table class="ds-player-table">
      <tbody>
        {{#each players}}
        <tr data-user-id="{{this.id}}" class="{{#unless this.active}}offline{{/unless}}">
          <td class="ds-player-swatch"><span style="background:{{this.color}}"></span></td>
          <td class="ds-player-name">
            <strong>{{this.name}}</strong>
            <small>{{this.character}}</small>
          </td>
          <td class="ds-player-perm">
            <select data-ds-permission title="{{localize 'dynamic-spectator.dashboard.permission'}}">
              {{#each this.permissionOptions}}
              <option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
              {{/each}}
            </select>
          </td>
          <td class="ds-player-actions">
            <button type="button" data-action="spectatePlayer" {{#unless this.hasToken}}disabled{{/unless}} title="{{localize 'dynamic-spectator.dashboard.spectate'}}">
              <i class="fa-solid fa-eye"></i>
            </button>
          </td>
        </tr>
        {{/each}}
      </tbody>
    </table>
    {{else}}
    <p class="ds-empty">—</p>
    {{/if}}
  </section>
</div>
